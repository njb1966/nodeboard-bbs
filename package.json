{
  "name": "nodeboard-bbs",
  "version": "1.1.0",
  "description": "NodeBoard BBS - A modern BBS system inspired by WWIV, Synchronet, and Wildcat with telnet access and DOOR game support",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "init-db": "node src/database/init.js"
  },
  "keywords": [
    "bbs",
    "telnet",
    "ssh",
    "ansi",
    "bulletin-board",
    "wwiv",
    "synchronet"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.10.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "rss-parser": "^3.13.0",
    "ssh2": "^1.17.0",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
